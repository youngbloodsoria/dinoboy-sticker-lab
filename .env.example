# Optional local reference only. This static site reads browser config from
# js/appConfig.js unless a future build step is added.
#
# Never place SUPABASE_SERVICE_ROLE_KEY in frontend code.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Server-side only. Set these in Vercel Project Settings > Environment Variables.
# Do not expose SENDGRID_API_KEY in frontend JavaScript.
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=roarbackproject@nudgeadvisors.com
SENDGRID_REPLY_TO_EMAIL=roarbackproject@nudgeadvisors.com
